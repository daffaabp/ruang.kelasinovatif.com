generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  hashedPassword    String
  role              Role                @default(MEMBER)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tokens            UserToken[]
  UserProfile       UserProfile[]
  UserCourseDetails UserCourseDetails[]

  @@map("users")
}

model UserToken {
  id        String    @id @default(cuid())
  userId    String
  type      TokenType
  token     String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_tokens")
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String
  firstName   String
  lastName    String
  phone       String
  institution String
  address     String
  city        String
  province    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

enum CourseType {
  EBOOK
  VIDEO
}

enum AccessType {
  FREE
  PREMIUM
}

model Courses {
  id                String          @id @default(cuid())
  courseName        String
  courseDescription String
  price             String?
  linkPayment       String?
  accessType        AccessType      @default(PREMIUM)
  thumbnailUrl      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt
  CourseDetails     CourseDetails[]

  @@map("courses")
}

model CourseDetails {
  id                String              @id @default(cuid())
  courseId          String
  title             String
  description       String
  courseType        CourseType
  videoUrl          String?
  downloadUrl       String?
  sortOrder         Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  course            Courses             @relation(fields: [courseId], references: [id], onDelete: Restrict)
  UserCourseDetails UserCourseDetails[]

  @@map("course_details")
}

enum NotificationType {
  NEW_USER_REGISTERED
  ACCESS_GRANTED
  NEW_CONTENT
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model UserCourseDetails {
  id             String        @id @default(cuid())
  userId         String
  courseDetailId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseDetail   CourseDetails @relation(fields: [courseDetailId], references: [id], onDelete: Cascade)

  @@unique([userId, courseDetailId])
  @@index([userId])
  @@index([courseDetailId])
  @@map("user_course_details")
}
